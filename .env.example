# ═══════════════════════════════════════════════════
# APS AI Predictor — Environment Variables Template
# Copy to .env and fill in values. NEVER commit .env
# ═══════════════════════════════════════════════════

# MongoDB Atlas URI
SPRING_DATA_MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/aipredictor?retryWrites=true&w=majority

# JWT Secret (64 hex chars)
JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend API URL (fill after Render backend deploys)
REACT_APP_API_BASE=https://ai-predictor-backend.onrender.com/api

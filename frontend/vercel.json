{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_API_BASE": "https://ai-predictor-backend.onrender.com/api"
  },
  "buildEnv": {
    "REACT_APP_API_BASE": "https://ai-predictor-backend.onrender.com/api"
  }
}
